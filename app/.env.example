# ── Backend ─────────────────────────────────────────────────────
APP_ID=tiger-head-worldcup
APP_SECRET=your-secret-key-change-me

# ── Database ───────────────────────────────────────────────────
# MySQL connection string format: mysql://user:password@host:port/database
# 本地开发示例（XAMPP/WAMP）：
#   DATABASE_URL=mysql://root:@localhost:3306/worldcup
# Docker 示例：
#   DATABASE_URL=mysql://root:password@localhost:3306/worldcup
# 生产环境示例：
#   DATABASE_URL=mysql://user:pass@your-server:3306/worldcup
DATABASE_URL=

# ── Admin ──────────────────────────────────────────────────────
# 首次运行 seed.ts 时会创建默认管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
